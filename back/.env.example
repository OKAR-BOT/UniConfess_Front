PORT=4000
NODE_ENV=development

# Database (sqlite | postgres | mysql)
DB_DIALECT=sqlite
DB_STORAGE=./data/database.sqlite

# For PostgreSQL / MySQL (when migrating)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=uconfess
DB_USER=postgres
DB_PASSWORD=

# JWT
JWT_SECRET=changeme_to_a_random_secret
JWT_EXPIRES_IN=7d

# OTP por correo
OTP_SECRET=changeme_to_another_random_secret
OTP_LENGTH=6
OTP_EXPIRES_MINUTES=10
OTP_MAX_ATTEMPTS=5
OTP_MAX_PER_HOUR=5

# SMTP / correo
SMTP_URL=
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="UConfess <noreply@cable-visiont.com>"

# CORS
CORS_ORIGIN=http://localhost:3000

# Admin seed
ADMIN_EMAIL=george.villachica@gmail.com
ADMIN_PASSWORD=admin123
